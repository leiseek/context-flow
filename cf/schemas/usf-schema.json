{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Universal Session Format (USF)",
  "description": "Cross-tool session context snapshot for ContextFlow",
  "type": "object",
  "required": ["version", "source", "snapshot", "file_state", "conversation", "tool_calls", "decisions", "current_intent"],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "USF schema version"
    },
    "source": {
      "type": "object",
      "required": ["tool", "model"],
      "properties": {
        "tool": { "type": "string", "enum": ["opencode", "claude-code", "codex", "cursor", "copilot-cli", "gemini-cli"] },
        "model": { "type": ["string", "null"] }
      }
    },
    "snapshot": {
      "type": "object",
      "required": ["timestamp", "session_id", "duration_minutes", "total_messages", "total_tool_calls"],
      "properties": {
        "timestamp": { "type": "string", "format": "date-time" },
        "session_id": { "type": "string" },
        "duration_minutes": { "type": "integer", "minimum": 0 },
        "total_messages": { "type": "integer", "minimum": 0 },
        "total_tool_calls": { "type": "integer", "minimum": 0 }
      }
    },
    "file_state": {
      "type": "object",
      "required": ["modified", "created", "deleted", "current_branch", "uncommitted_count"],
      "properties": {
        "modified": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "path": { "type": "string" },
              "diff": { "type": ["string", "null"] }
            }
          }
        },
        "created": {
          "type": "array",
          "items": { "type": "object", "properties": { "path": { "type": "string" } } }
        },
        "deleted": { "type": "array", "items": { "type": "string" } },
        "current_branch": { "type": ["string", "null"] },
        "uncommitted_count": { "type": "integer", "minimum": 0 }
      }
    },
    "conversation": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["role", "content"],
        "properties": {
          "role": { "type": "string", "enum": ["user", "assistant", "system", "tool"] },
          "content": { "type": "string" }
        }
      }
    },
    "tool_calls": {
      "type": "object",
      "properties": {
        "compatible": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "tool": { "type": "string" },
              "args": { "type": "object" }
            }
          }
        },
        "incompatible": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "tool": { "type": "string" },
              "args": { "type": "object" },
              "result_summary": { "type": "string" }
            }
          }
        }
      }
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "topic": { "type": "string" },
          "chosen": { "type": "string" },
          "rejected": { "type": "array", "items": { "type": "string" } },
          "reasoning": { "type": "string" }
        }
      }
    },
    "current_intent": {
      "type": "object",
      "properties": {
        "task": { "type": ["string", "null"] },
        "completed": { "type": "array", "items": { "type": "string" } },
        "in_progress": { "type": "array", "items": { "type": "string" } },
        "next_steps": { "type": "array", "items": { "type": "string" } },
        "blockers": { "type": "array", "items": { "type": "string" } },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    }
  }
}
